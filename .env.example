# Copy this file to ".env" and fill in your own values.
# NEVER commit your real .env file — it is ignored by .gitignore.

# Contact e-mail required by the NCBI Entrez API.
NCBI_EMAIL=your_email@example.com

# Optional NCBI API key. Increases the request rate limit (3 -> 10 req/s).
# Generate one at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=your_ncbi_api_key

# Absolute or relative path where searchSRA.py writes the search results,
# and from which concat.py reads them.
OUTPUT_FILE_LIST_SRA=results/resultados_busca_sra.csv

# Absolute or relative path where querySRA.py writes the extracted metadata.
OUTPUT_FILE_LIST_METADATA=results/sra_metadata.csv
